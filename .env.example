# Copy this file to `.env` in the project root and set your values.
# See README.md for full setup. At least one API key is required.

# OpenAI (sk-...) — primary path for this starter
OPENAI_API_KEY=

# OpenRouter (sk-or-v1-...) — optional; provider switching is prepared in config.js
# OPENROUTER_API_KEY=

# Optional: force provider — openai | openrouter (if unset, picks from which key is present)
# AI_PROVIDER=openai

# OpenRouter-only: optional headers some setups require (see config.js)
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_APP_NAME=
